services:
  laravel.test:
    build:
      context: .
      dockerfile: Dockerfile
    user: root
    networks:
      - sail
      - proxy
    ports:
      - '${APP_PORT:-8000}:8000'
    labels:
      - "traefik.enable=true"
            # Menerima dari akses internet ATAU akses lokal
      - "traefik.http.routers.ksp.rule=Host(`${APP_DOMAIN}`) || Host(`${LOCAL_DOMAIN}`)"
      - "traefik.http.routers.ksp.entrypoints=web"
      - "traefik.http.services.ksp.loadbalancer.server.port=8000"
      - "traefik.docker.network=proxy"
      # - "traefik.http.routers.ksp.middlewares=auth-ksp" # Tempat pasang middleware nanti
    environment:
      TZ: Asia/Jakarta
      PUID: '${WWWUSER}'
      PGID: '${WWWGROUP}'
      LARAVEL_SAIL: 1
      XDEBUG_MODE: '${SAIL_XDEBUG_MODE:-off}'
      IGNITION_LOCAL_SITES_PATH: '${PWD}'
    privileged: true
    volumes:
      - '.:/var/www/html'
      - '/var/run/docker.sock:/var/run/docker.sock'
      - '/var/run/tailscale/tailscaled.sock:/var/run/tailscale/tailscaled.sock'
      - '/run/udev:/run/udev:ro'
      - '/etc/machine-id:/etc/machine-id:ro'
      - '/sys:/host/sys:ro'
    command: ["/var/www/html/docker/start.sh"]
    restart: unless-stopped
    depends_on:
      mysql:
        condition: service_healthy
      redis:
        condition: service_healthy
      minio:
        condition: service_started


  tailscale-watchdog:
    build:
      context: ./docker/tailscale
      dockerfile: Dockerfile.watchdog
    environment:
      TZ: Asia/Jakarta
      TS_AUTHKEY: "${TS_AUTHKEY}"
      TS_SOCKET: "/var/run/tailscale/tailscaled.sock"
    volumes:
      - "/var/run/tailscale/tailscaled.sock:/var/run/tailscale/tailscaled.sock"
    networks:
      - sail
    restart: unless-stopped


  mysql:
    image: 'mysql/mysql-server:8.0'
    ports:
      - '${FORWARD_DB_PORT:-3306}:3306'
    environment:
      TZ: Asia/Jakarta
      MYSQL_ROOT_PASSWORD: '${DB_PASSWORD}'
      MYSQL_ROOT_HOST: "%"
      MYSQL_DATABASE: '${DB_DATABASE}'
      MYSQL_USER: '${DB_USERNAME}'
      MYSQL_PASSWORD: '${DB_PASSWORD}'
      MYSQL_ALLOW_EMPTY_PASSWORD: 1
    volumes:
      - 'sail-mysql:/var/lib/mysql'
    networks:
      - sail
    restart: unless-stopped
    healthcheck:
      test: [ "CMD", "mysqladmin", "ping", "-p${DB_PASSWORD}" ]
      retries: 3
      timeout: 5s
      interval: 5s

  minio:
    image: 'minio/minio:latest'
    networks:
      - sail
    ports:
      - '${FORWARD_MINIO_PORT:-9000}:9000'
      - '${FORWARD_MINIO_CONSOLE_PORT:-8900}:8900'
    depends_on:
      - mysql
    environment:
      MINIO_ROOT_USER: 'sail'
      MINIO_ROOT_PASSWORD: 'password'
    volumes:
      - 'sail-minio:/data/minio'
    restart: unless-stopped
    command: 'minio server /data/minio --address ":9000" --console-address ":8900"'

  createbuckets:
    image: minio/mc
    depends_on:
      - minio
    environment:
      MINIO_ROOT_USER: 'sail'
      MINIO_ROOT_PASSWORD: 'password'
      BUCKET_NAME: '${AWS_BUCKET:-local}'
    entrypoint: >
      /bin/sh -c " /usr/bin/mc alias set myminio http://minio:9000 sail password; /usr/bin/mc mb myminio/${AWS_BUCKET:-local}; /usr/bin/mc anonymous set public myminio/${AWS_BUCKET:-local}; exit 0; "
    networks:
      - sail

  redis:
    image: 'redis:alpine'
    ports:
      - '${FORWARD_REDIS_PORT:-6379}:6379'
    volumes:
      - 'sail-redis:/data'
    networks:
      - sail
    restart: unless-stopped
    healthcheck:
      test: [ "CMD", "redis-cli", "ping" ]
      retries: 3
      timeout: 5s
      interval: 5s

  queue-worker:
    build:
      context: .
      dockerfile: Dockerfile
    extra_hosts:
      - 'host.docker.internal:host-gateway'
    environment:
      TZ: Asia/Jakarta
      PUID: '${WWWUSER}'
      PGID: '${WWWGROUP}'
      LARAVEL_SAIL: 1
      XDEBUG_MODE: '${SAIL_XDEBUG_MODE:-off}'
      IGNITION_LOCAL_SITES_PATH: '${PWD}'
    volumes:
      - '.:/var/www/html'
      - '/run/udev:/run/udev:ro'
    networks:
      - sail
    depends_on:
      - laravel.test
      - mysql
      - redis
    restart: unless-stopped
    command: php artisan queue:work --sleep=3 --tries=3 --max-time=3600

  reverb:
    build:
      context: .
      dockerfile: Dockerfile
    environment:
      TZ: Asia/Jakarta
      PUID: '${WWWUSER}'
      PGID: '${WWWGROUP}'
      LARAVEL_SAIL: 1
      XDEBUG_MODE: '${SAIL_XDEBUG_MODE:-off}'
      IGNITION_LOCAL_SITES_PATH: '${PWD}'
      REVERB_APP_ID: '${REVERB_APP_ID}'
      REVERB_APP_KEY: '${REVERB_APP_KEY}'
      REVERB_APP_SECRET: '${REVERB_APP_SECRET}'
      REVERB_HOST: "0.0.0.0"
      REVERB_PORT: 8080
      REVERB_SCHEME: "http"
    networks:
      - sail
    volumes:
      - '.:/var/www/html'
      - '/run/udev:/run/udev:ro'
    depends_on:
      laravel.test:
        condition: service_started
      redis:
        condition: service_healthy
    restart: unless-stopped
    command: php artisan reverb:start

  scheduler:
    build:
      context: .
      dockerfile: Dockerfile
    extra_hosts:
      - 'host.docker.internal:host-gateway'
    environment:
      TZ: Asia/Jakarta
      PUID: '${WWWUSER}'
      PGID: '${WWWGROUP}'
      LARAVEL_SAIL: 1
      XDEBUG_MODE: '${SAIL_XDEBUG_MODE:-off}'
      IGNITION_LOCAL_SITES_PATH: '${PWD}'
    volumes:
      - '.:/var/www/html'
      - '/run/udev:/run/udev:ro'
    networks:
      - sail
    depends_on:
      - laravel.test
      - mysql
      - redis
    restart: unless-stopped
    command: php artisan schedule:work

  mailpit:
    image: 'axllent/mailpit:latest'
    ports:
      - '${FORWARD_MAILPIT_PORT:-1025}:1025'
      - '${FORWARD_MAILPIT_DASHBOARD_PORT:-8025}:8025'
    networks:
      - sail
    restart: unless-stopped

networks:
  sail:
    driver: bridge
  proxy:
    external: true

volumes:
  sail-mysql:
    driver: local
  sail-minio:
    driver: local
  sail-redis:
    driver: local
